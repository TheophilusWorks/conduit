{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "target": "ES2022",
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "declaration": true,
    "isolatedModules": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
